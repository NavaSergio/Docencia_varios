    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# 10. Flujo completo recomendado"
      ],
      "id": "13c49768"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "def run_pca_workflow(root_dir):\n",
        "    X, y, feature_names, meta = build_dataset_from_folders(root_dir)\n",
        "\n",
        "    # Limpieza preventiva\n",
        "    X = np.nan_to_num(X, nan=0.0, posinf=0.0, neginf=0.0)\n",
        "\n",
        "    # PCA 2D\n",
        "    Z2, pca2 = pca_2d_projection(X)\n",
        "    plot_pca_2d(Z2, y, pca2)\n",
        "\n",
        "    # PCA 3D\n",
        "    Z3, pca3 = pca_3d_projection(X)\n",
        "    plot_pca_3d(Z3, y, pca3)\n",
        "\n",
        "    return X, y, feature_names, meta, Z2, Z3, pca2, pca3"
      ],
