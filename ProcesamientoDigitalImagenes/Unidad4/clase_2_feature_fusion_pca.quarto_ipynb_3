      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# 1. Funciones de extracción\n",
        "\n",
        "En esta clase reutilizamos la idea de la clase anterior, pero dejaremos las funciones listas para un flujo más completo."
      ],
      "id": "fbe78f82"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "def extract_glcm_features(\n",
        "    image_gray,\n",
        "    levels=32,\n",
        "    distances=(1, 3, 5),\n",
        "    angles=(0, np.pi / 4, np.pi / 2, 3 * np.pi / 4),\n",
        "):\n",
        "    q = (image_gray / 256 * levels).astype(np.uint8)\n",
        "    q = np.clip(q, 0, levels - 1)\n",
        "\n",
        "    glcm = graycomatrix(\n",
        "        q,\n",
        "        distances=list(distances),\n",
        "        angles=list(angles),\n",
        "        levels=levels,\n",
        "        symmetric=True,\n",
        "        normed=True,\n",
        "    )\n",
        "\n",
        "    props = [\"contrast\", \"dissimilarity\", \"homogeneity\", \"ASM\", \"energy\", \"correlation\"]\n",
        "    feats = []\n",
        "    names = []\n",
        "    for prop in props:\n",
        "        vals = graycoprops(glcm, prop)\n",
        "        for i, d in enumerate(distances):\n",
        "            for j, _ in enumerate(angles):\n",
        "                feats.append(vals[i, j])\n",
        "                names.append(f\"glcm_{prop}_d{d}_a{j}\")\n",
        "\n",
        "    return np.array(feats, dtype=float), names\n",
        "\n",
        "\n",
        "def extract_hu_features(image_gray, threshold=110):\n",
        "    _, mask = cv2.threshold(image_gray, threshold, 255, cv2.THRESH_BINARY)\n",
        "    moments = cv2.moments(mask)\n",
        "    hu = cv2.HuMoments(moments).flatten()\n",
        "    hu_log = -np.sign(hu) * np.log10(np.abs(hu) + 1e-12)\n",
        "    names = [f\"hu_{i+1}\" for i in range(7)]\n",
        "    return hu_log.astype(float), names\n",
        "\n",
        "\n",
        "def extract_color_moments(image_rgb):\n",
        "    feats = []\n",
        "    names = []\n",
        "    for idx in range(3):\n",
        "        channel = image_rgb[:, :, idx].astype(np.float64).ravel()\n",
        "        feats.extend([\n",
        "            channel.mean(),\n",
        "            channel.std(ddof=0),\n",
        "            skew(channel, bias=False),\n",
        "        ])\n",
        "        cname = [\"R\", \"G\", \"B\"][idx]\n",
        "        names.extend([\n",
        "            f\"color_mean_{cname}\",\n",
        "            f\"color_std_{cname}\",\n",
        "            f\"color_skew_{cname}\",\n",
        "        ])\n",
        "    return np.array(feats, dtype=float), names\n",
        "\n",
        "\n",
        "def extract_fused_features(image_rgb):\n",
        "    gray = cv2.cvtColor(image_rgb, cv2.COLOR_RGB2GRAY)\n",
        "    g, g_names = extract_glcm_features(gray)\n",
        "    h, h_names = extract_hu_features(gray)\n",
        "    c, c_names = extract_color_moments(image_rgb)\n",
        "    return np.concatenate([g, h, c]), g_names + h_names + c_names"
      ],
      "id": "7859c0e2",
      "execution_count": null,
      "outputs": []
    },
    {
